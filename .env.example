DATABASE_URL=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk Dashboard → Webhooks → Signing secret (Svix)
# CLERK_WEBHOOK_SECRET_KEY=
# Optional but strongly recommended for local/Edge: Dashboard → API keys → “JWT public key” → PEM.
# Avoids middleware calling Clerk’s JWKS over the network (fixes handshake “fetch failed” on some networks).
# One line with \n between PEM lines (or real newlines). Middleware turns \n into newlines.
# CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\nMIIBI...\n-----END PUBLIC KEY-----"
#
# --- Clerk + Vercel (deploy) + ngrok (local webhooks) ---
# Use Vercel for the live app; use ngrok only to tunnel Stripe/Clerk webhooks to localhost while developing.
# Always use full https origins in Clerk (never bare hostnames like cart2barrelstripe.ngrok.app — that becomes
# a relative path and breaks links, e.g. vercel.app/cart2barrelstripe.ngrok.app → 404).
#
# Clerk Dashboard → Configure → Domains: add BOTH origins when sharing one Clerk app:
#   Production: https://shopping-cart2-barrel.vercel.app
#   Local tunnel: https://cart2barrelstripe.ngrok.app
#
# Clerk Dashboard → Configure → Paths: use “development host” (your app), NOT Account Portal.
# Set Home / Paths to whichever origin you are actively using:
#
#   Production (Vercel):
#     Home URL ............... https://shopping-cart2-barrel.vercel.app
#     Sign-in ................ https://shopping-cart2-barrel.vercel.app/login
#     Sign-up ................ https://shopping-cart2-barrel.vercel.app/signup
#     After sign-in / sign-up  https://shopping-cart2-barrel.vercel.app/welcome
#     Webhook ................ https://shopping-cart2-barrel.vercel.app/api/webhooks/clerk
#
#   Local dev (ngrok tunnel to npm run dev on :3001):
#     Home URL ............... https://cart2barrelstripe.ngrok.app
#     Sign-in ................ https://cart2barrelstripe.ngrok.app/login
#     Sign-up ................ https://cart2barrelstripe.ngrok.app/signup
#     After sign-in / sign-up  https://cart2barrelstripe.ngrok.app/welcome
#     Webhook ................ https://cart2barrelstripe.ngrok.app/api/webhooks/clerk
#     (Point Stripe webhook to https://cart2barrelstripe.ngrok.app/api/webhooks/stripe while testing locally;
#      switch both webhooks back to Vercel URLs before relying on production.)
#
# Extra allowed token origins (comma-separated). Useful when NEXT_PUBLIC_APP_URL is ngrok but you still
# open the Vercel deployment with the same Clerk keys:
# CLERK_AUTHORIZED_PARTIES=https://shopping-cart2-barrel.vercel.app
# Only enable if Clerk.js truly cannot reach Clerk (can cause host_invalid if misconfigured):
# CLERK_FRONTEND_API_PROXY=true

# SerpApi (server): Google Shopping compare + Walmart/Amazon/immersive store variants
# https://serpapi.com/manage-api-key
SERPAPI_API_KEY=

# OpenAI (server): admin “AI estimate” fetches product HTML and extracts fields
OPENAI_API_KEY=
# Optional; default gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Optional: Jina Reader fallback when retailers return HTTP 403 to server fetch (https://jina.ai/reader)
# JINA_READER_API_KEY=

# Vercel Blob read/write token (dashboard → Storage → Blob → create token).
# Used for: retailer receipt screenshots on paid lines; customer product photos on item requests;
# inbound barcode photos on order lines. Path prefixes: retailer-receipts/, product-images/, warehouse-barcodes/
BLOB_READ_WRITE_TOKEN=

# Admin estimate: tax (bps on merchandise+service+shipping), flat shipping cents per line.
# Service & handling is tiered per item by unit price — see src/lib/admin-markup.ts and .cursor/rules/cart2barrel-service-handling-fees.mdc
ADMIN_TAX_BPS=0
ADMIN_DEFAULT_SHIPPING_CENTS=0000

# Match your Clerk Paths (app routes, not Account Portal URLs)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
# Optional; align with <SignIn>/<SignUp> forceRedirectUrl in src/components/auth/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/welcome
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/welcome
#
# Performance: add `role` to the session JWT (Clerk Dashboard → Sessions → Customize session token),
# e.g. `"role": "{{user.public_metadata.role}}"`, so layouts can verify admin without calling
# Clerk's Backend API on every navigation.

# Checkout: optional pass-through surcharge (bps + fixed cents on merchandise subtotal). Region from primary shipping address country (US vs other).
# Set STRIPE_CHECKOUT_SURCHARGE_ENABLED=false to disable. Defaults approximate common US vs international card pricing.
# STRIPE_CHECKOUT_SURCHARGE_ENABLED=true
# STRIPE_CHECKOUT_SURCHARGE_US_BPS=290
# STRIPE_CHECKOUT_SURCHARGE_US_FIXED_CENTS=30
# STRIPE_CHECKOUT_SURCHARGE_INTL_BPS=390
# STRIPE_CHECKOUT_SURCHARGE_INTL_FIXED_CENTS=30

# Checkout: Stripe line_items include a combined "Estimated sales tax" row when quoted sale tax
# from batch estimates / item quotes clears Stripe’s US $0.50 minimum-per-line rule; otherwise tax
# stays embedded in merchandise lines while totals stay unchanged. (This is invoice visibility for
# staff-quoted retailer/site taxes, not Stripe Tax automatic calculation.)

# Stripe — optional: simplify hosted Checkout (fewer BNPL / bank rails). Comma-separated Stripe payment method type ids, or `none` for full Dashboard list.
# Examples: affirm,amazon_pay,klarna,us_bank_account
# STRIPE_CHECKOUT_EXCLUDED_PAYMENT_METHOD_TYPES=affirm,amazon_pay,klarna,us_bank_account
# STRIPE_CHECKOUT_EXCLUDED_PAYMENT_METHOD_TYPES=none
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Embedded Checkout on your site (default). Requires NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY.
# Use hosted redirect-only Checkout on Stripe if you omit the publishable key:
# STRIPE_CHECKOUT_UI_MODE=hosted
#
# Client Stripe.js (Dashboard → API keys → Publishable key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Canonical app origin for Stripe Checkout return URLs and Clerk session handshakes.
# Must match the active Clerk Home URL and include https:// (no trailing slash).
#
# Local without tunnel:
#   NEXT_PUBLIC_APP_URL=http://localhost:3001
# Local with ngrok (webhook / Stripe testing):
#   NEXT_PUBLIC_APP_URL=https://cart2barrelstripe.ngrok.app
# Vercel production (set in Vercel → Project → Environment Variables):
#   NEXT_PUBLIC_APP_URL=https://shopping-cart2-barrel.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Ngrok (Windows): use IPv4 upstream so the agent does not dial [::1] while Next listens on 127.0.0.1 (fixes ERR_NGROK_8012).
# Start dev server first, then:
#   ngrok http --url=cart2barrelstripe.ngrok.app http://127.0.0.1:3001
# Host is also listed in next.config.ts allowedDevOrigins for HMR over the tunnel.

# Email (Resend: https://resend.com) — receipts, optional delivery notifications when using requestDeliveryForOrderItemAction
RESEND_API_KEY=
# Verified sender domain in Resend (e.g. Cart2Barrel <notify@yourdomain.com>)
RESEND_FROM_EMAIL=
# Payment invoice / PDF receipt (Account → Billing Receipt)
# INVOICE_COMPANY_NAME=Cart2Barrel
# INVOICE_COMPANY_ADDRESS_LINE1=Your business street
# INVOICE_COMPANY_ADDRESS_LINE2=City, State ZIP
# INVOICE_COMPANY_ADDRESS_LINE3=Country
# INVOICE_COMPANY_PHONE=
# INVOICE_COMPANY_EMAIL=notify@yourdomain.com

# Paid order receipt email (sent once per order after Stripe checkout succeeds).
# Comma-separated operations / warehouse inbox for legacy server action `requestDeliveryForOrderItemAction` if you invoke it programmatically (admin Purchase orders manages tracking in the UI)
DELIVERY_OPS_EMAIL=
# Set to false to skip the shopper confirmation email (ops email still needs config above)
# DELIVERY_NOTIFY_CUSTOMER=true
